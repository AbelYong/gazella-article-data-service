<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ArticleService</AssemblyName>
    <RootNamespace>ArticleService</RootNamespace>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
  </PropertyGroup>

  <ItemGroup>
    <Protobuf Include="Protos\draft_service.proto" GrpcServices="Server" />
    <Protobuf Include="Protos\article_service.proto" GrpcServices="Server" />
    <Protobuf Include="Protos\review_service.proto" GrpcServices="Server" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" Version="2.57.0" />
    <PackageReference Include="MongoDB.EntityFrameworkCore" Version="8.4.1" />
  </ItemGroup>

</Project>
